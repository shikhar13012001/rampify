# ── Stripe ──────────────────────────────────────────────────────────────────
# Server-side only (never expose to the client)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create both prices in Stripe Dashboard → Products → Add product
# Monthly recurring: $12/month
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# Annual recurring: $96/year (= $8/month)
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Legacy fallback (used if STRIPE_PRO_MONTHLY_PRICE_ID is unset)
STRIPE_PRO_PRICE_ID=price_...
# Set to 1 ONLY for local `vercel dev` webhook testing. NEVER set in production
# or preview. When unset, the webhook endpoint requires a valid Stripe signature
# and rejects empty bodies (the dev bypass was previously implicit — closing a
# privilege-escalation hole on public Vercel dev deployments).
STRIPE_WEBHOOK_DEV_BYPASS=0

# ── Allowed redirect origins for Stripe Checkout ─────────────────────────────
# Comma-separated list of production origins that the checkout success/cancel
# URLs may redirect to. The first entry is used as the fallback when the
# request omits an Origin header. Preview deployments are auto-allowed via
# VERCEL_URL; localhost is allowed automatically for dev.
ALLOWED_ORIGINS=https://your-production-domain.example.com

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Paste the entire service account JSON as a single line (escape quotes as needed).
# Generate at: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ── Firebase Client SDK (Vite public env — prefixed VITE_) ───────────────────
# All values from: Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
